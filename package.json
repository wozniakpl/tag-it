{
  "name": "tag-it",
  "version": "1.3.0",
  "description": "GitHub Action for Conventional Commits validation and semantic versioning",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format esm --out-dir dist --no-splitting --minify",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "prepare": "husky"
  },
  "keywords": [
    "github-action",
    "semantic-versioning",
    "conventional-commits"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^6.0.0",
    "semver": "^7.5.4"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/semver": "^7.5.6",
    "husky": "^9.1.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.0"
  }
}
